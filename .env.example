# ---- Qwen Cloud (Alibaba Cloud Model Studio / DashScope) ----
# OpenAI-compatible endpoint. Get the key from Model Studio → API-KEY.
DASHSCOPE_API_KEY=sk-your-key-here
# International endpoint (default). Mainland China: https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ---- Model routing (cost control) ----
AGENT_MODEL=qwen-plus       # orchestrator reasoning; switch to qwen-max for the final demo
FAST_MODEL=qwen-turbo       # cheap routing / extraction / classification
VISION_MODEL=qwen-vl-max    # photo -> product matching

# ---- ImpalaFlow API (existing backend) ----
IMPALAFLOW_BASE_URL=https://api.impalaflow.com
# Public app URL, used to build shareable invoice/pay links.
IMPALAFLOW_APP_URL=https://impalaflow.com
IMPALAFLOW_EMAIL=you@example.com
IMPALAFLOW_PASSWORD=your-password
# Optional: force a tenant id. If blank, taken from the login response.
IMPALAFLOW_TENANT_ID=
# Timezone header sent on login (matches how the web app logs in).
IMPALAFLOW_TIMEZONE=Africa/Lagos
